{
  "name": "gitmag",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "gitmag": "./dist/index.js"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "commander": "^14.0.3",
    "conf": "^15.1.0",
    "diff2html": "^3.4.56",
    "ecc-universal": "^1.8.0",
    "fast-glob": "^3.3.3",
    "highlight.js": "^11.11.1",
    "ink": "^5.2.1",
    "ink-select-input": "^6.2.0",
    "react": "^18.3.1",
    "simple-git": "^3.33.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@eslint/js": "^10.0.1",
    "@types/react": "^18.2.79",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
